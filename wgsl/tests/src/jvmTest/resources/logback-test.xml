<configuration>
    <!-- Console appender - clean output for golden tests -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- Main test log file -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>build/test-logs.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Separate file for exception details -->
    <appender name="EXCEPTION_FILE" class="ch.qos.logback.core.FileAppender">
        <file>build/reports/golden-exceptions.log</file>
        <append>false</append>
        <encoder>
            <pattern>%date [%thread] %-5level %logger{36} - %msg%n%ex%n</pattern>
        </encoder>
    </appender>

    <!-- Golden test logger - goes to both console and files -->
    <logger name="io.ygdrasil.wgsl.tests" level="INFO" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="EXCEPTION_FILE"/>
    </logger>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
